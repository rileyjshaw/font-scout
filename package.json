		"lucide-react": "^1.7.0",
		"prettier": "^3.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-helmet-async": "^3.0.0",
		"react-select": "^5.10.2",
		"react-use-keypress": "^1.4.0",
		"react-window": "^2.2.7",
