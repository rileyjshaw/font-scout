{
	"name": "font-scout",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"dependencies": {
		"@radix-ui/react-label": "^2.1.11",
		"@radix-ui/react-popover": "^1.1.19",
		"@radix-ui/react-slider": "^1.4.3",
		"@radix-ui/react-slot": "^1.3.0",
		"@react-hook/hover": "^4.0.0",
		"@react-hook/resize-observer": "^2.0.2",
		"class-variance-authority": "^0.7.1",
		"cnz": "^1.1.1",
		"fuzzysort": "^3.1.0",
		"json-stable-stringify": "^1.3.0",
		"lucide-react": "^1.24.0",
		"prettier": "^3.9.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-helmet-async": "^3.0.0",
		"react-select": "^5.10.2",
		"react-use-keypress": "^1.4.0",
		"react-window": "^2.2.7",
		"request-promise-native": "^1.0.9",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.2",
		"@vitejs/plugin-react": "^6.0.3",
		"dotenv": "^17.4.2",
		"fontkit": "^2.0.4",
		"lint-staged": "^17.0.8",
		"opentype.js": "^2.0.0",
		"request": "^2.88.2",
		"vite": "^8.1.4",
		"wawoff2": "^2.0.1"
	},
	"scripts": {
		"start": "vite",
		"start-prod": "yarn build && serve -s build",
		"build": "vite build",
		"test": "node --test font_scripts/*.test.js",
		"scan-fonts": "node ./font_scripts/findFontFeatures.js",
		"fetch-google-fonts": "node --input-type=module -e \"import fetchFonts from './font_scripts/fetchGoogleFonts.js'; await fetchFonts();\"",
		"lint": "prettier --write \"{font_scripts,src}/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
		"update-fonts": "yarn scan-fonts && yarn fetch-google-fonts && yarn lint"
	},
	"eslintConfig": {
		"extends": [
			"react-app"
		]
	},
	"prettier": {
		"arrowParens": "avoid",
		"printWidth": 120,
		"singleQuote": true,
		"useTabs": true
	},
	"lint-staged": {
		"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
			"prettier --write"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"packageManager": "yarn@1.22.22"
}
